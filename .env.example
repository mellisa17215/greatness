# Example environment variables

# Server secret (keep private)
STRIPE_SECRET_KEY=sk_test_xxx_replace_with_yours

# Client publishable key (safe to expose)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx_replace_with_yours

# (Optional) webhook signing secret from Stripe
STRIPE_WEBHOOK_SECRET=whsec_xxx_replace_with_yours
